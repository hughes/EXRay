{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build EXRay",
            "type": "shell",
            "command": "bazelisk",
            "args": [
                "build",
                "//:EXRay"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "presentation": {
                "reveal": "silent",
                "revealProblems": "onProblem"
            }
        },
        {
            "label": "Build EXRay (debug)",
            "type": "shell",
            "command": "bazelisk",
            "args": [
                "build",
                "--config=dbg",
                "//:EXRay"
            ],
            "group": "build",
            "problemMatcher": [
                "$msCompile"
            ]
        },
        {
            "label": "Build Installer",
            "type": "shell",
            "command": "bazelisk",
            "args": [
                "build",
                "-c",
                "opt",
                "//:EXRay",
                "//:EXRayThumb.dll"
            ],
            "group": "build",
            "problemMatcher": [
                "$msCompile"
            ],
            "presentation": {
                "reveal": "silent",
                "revealProblems": "onProblem"
            },
            "dependsOrder": "sequence"
        },
        {
            "label": "Stage Installer",
            "type": "shell",
            "command": "Copy-Item -Path bazel-out/x64_windows-opt/bin/EXRay.exe, bazel-out/x64_windows-opt/bin/EXRayThumb.dll -Destination installer/; attrib -R installer\\EXRay.exe; attrib -R installer\\EXRayThumb.dll",
            "group": "build",
            "dependsOn": "Build Installer"
        },
        {
            "label": "Run Validation Tests",
            "type": "shell",
            "command": "./bazel-bin/EXRay.exe",
            "args": [
                "--validate",
                "tests/images",
                "tests/validate_results.txt"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "dependsOn": "Build EXRay",
            "problemMatcher": []
        },
        {
            "label": "Format Code",
            "type": "shell",
            "command": "Get-ChildItem -Path src,tests -Include *.cpp,*.h -Recurse | ForEach-Object { clang-format -i --style=file $_.FullName }",
            "group": "build",
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "Run Unit Tests",
            "type": "shell",
            "command": "bazelisk",
            "args": [
                "test",
                "//:all",
                "--test_output=errors"
            ],
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "problemMatcher": []
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "bazelisk",
            "args": [
                "clean"
            ],
            "group": "build"
        }
    ]
}
